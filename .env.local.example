# Supabase — from your project's API settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Used only for provisioning/seeding and the server-side email send.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend) — configured by us, the customer sets nothing.
EMAIL_API_KEY=re_your_resend_api_key
EMAIL_FROM="Henry Schedules <schedules@yourdomain.com>"
